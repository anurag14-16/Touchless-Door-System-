#include <Servo.h>
#include <LiquidCrystal_I2C.h>

// Pin definitions
const int TRIG_PIN   = 9;
const int ECHO_PIN   = 10;
const int SERVO_PIN  = 6;
const int GREEN_LED  = 7;
const int RED_LED    = 8;

// Threshold distance in cm
const int TRIGGER_DIST = 20;

// Door open duration in ms
const int DOOR_OPEN_TIME = 3000;

Servo myServo;
LiquidCrystal_I2C lcd(0x27, 16, 2);

bool doorOpen = false;

void setup() {
  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);
  pinMode(GREEN_LED, OUTPUT);
  pinMode(RED_LED, OUTPUT);

  myServo.attach(SERVO_PIN);
  lcd.init();
  lcd.backlight();

  setDoorState(false);   // Start closed
  Serial.begin(9600);
}

float getDistance() {
  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);
  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);
  digitalWrite(TRIG_PIN, LOW);

  long duration = pulseIn(ECHO_PIN, HIGH);
  return duration * 0.034 / 2;
}

void setDoorState(bool open) {
  doorOpen = open;
  if (open) {
    myServo.write(90);           // Open position
    digitalWrite(GREEN_LED, HIGH);
    digitalWrite(RED_LED, LOW);
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Welcome!");
    lcd.setCursor(0, 1);
    lcd.print("Door Opening..");
  } else {
    myServo.write(0);            // Closed position
    digitalWrite(GREEN_LED, LOW);
    digitalWrite(RED_LED, HIGH);
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Touchless Door");
    lcd.setCursor(0, 1);
    lcd.print("Status: CLOSED");
  }
}

unsigned long lastDetectedTime = 0;  // add this with your variables at top

void loop() {
  float distance = getDistance();

  Serial.print("Distance: ");
  Serial.println(distance);

  if (distance < TRIGGER_DIST && distance > 2 && distance < 400) {
    lastDetectedTime = millis();      // keep resetting timer

    if (!doorOpen) {
      setDoorState(true);             // only open if currently closed
    }
  }

  if (doorOpen && (millis() - lastDetectedTime > DOOR_OPEN_TIME)) {
    setDoorState(false);              // close only after 3 sec of no detection
  }

  delay(200);
}
