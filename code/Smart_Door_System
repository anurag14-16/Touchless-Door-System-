// Pin definitions
const int TRIG_PIN = 9;
const int ECHO_PIN = 10;

void setup() {
  pinMode(TRIG_PIN, OUTPUT);   // TRIG sends signal out
  pinMode(ECHO_PIN, INPUT);    // ECHO receives signal back
  Serial.begin(9600);          // Start Serial Monitor
}

void loop() {
  // Step 1: Clear the trigger pin first
  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);

  // Step 2: Send a 10 microsecond pulse
  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);
  digitalWrite(TRIG_PIN, LOW);

  // Step 3: Measure how long ECHO stays HIGH
  long duration = pulseIn(ECHO_PIN, HIGH);

  // Step 4: Calculate distance
  float distance = duration * 0.034 / 2;

  // Step 5: Print to Serial Monitor
  Serial.print("Distance: ");
  Serial.print(distance);
  Serial.println(" cm");

  delay(500); // Wait half a second before next reading
}// Pin definitions
